<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AnsiBoard - All hosts</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    .breadcrumb { margin-bottom: 20px; font-size: 14px; }
    .breadcrumb a { color: #0066cc; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .container { max-width: 1100px; margin: 0 auto; }
    .count { color: #666; font-size: 14px; margin-bottom: 16px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; }
    th { text-align: left; padding: 10px 16px; background: #f9f9f9; border-bottom: 2px solid #e0e0e0; font-weight: 500; font-size: 13px; color: #666; white-space: nowrap; cursor: pointer; user-select: none; }
    th:hover { color: #333; }
    th::after { content: ''; display: inline-block; margin-left: 4px; opacity: 0.3; }
    th[data-sort="asc"]::after { content: ' \25B2'; opacity: 1; }
    th[data-sort="desc"]::after { content: ' \25BC'; opacity: 1; }
    td { padding: 8px 16px; border-bottom: 1px solid #f0f0f0; font-size: 14px; white-space: nowrap; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f9f9f9; }
    td a { color: #333; text-decoration: none; font-weight: 500; }
    td a:hover { color: #0066cc; }
    .na { color: #ccc; }
    .stale { color: #e15759; }
    .chart-card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; display: flex; align-items: center; gap: 20px; }
    .donut-hole { background: #fff; }
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a1a; color: #e0e0e0; }
      table, .chart-card { background: #2a2a2a; border-color: #404040; }
      th { background: #333; border-color: #404040; color: #999; }
      th:hover { color: #e0e0e0; }
      td { border-color: #333; }
      tr:hover td { background: #333; }
      td a { color: #e0e0e0; }
      td a:hover { color: #6cb6ff; }
      .breadcrumb a { color: #6cb6ff; }
      .count { color: #999; }
      .na { color: #555; }
      .donut-hole { background: #2a2a2a; }
    }
  </style>
 </head>
 <body>
  <div class="container">
   <div class="breadcrumb"><a href="index.html">AnsiBoard</a> / All hosts</div>
   <h1>All hosts</h1>
   <p class="count">{{ groups['all'] | length }} host{{ 's' if groups['all'] | length != 1 }}</p>
{% set colors = ['#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f', '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ac'] %}
{% set now_epoch = now(utc=true).strftime('%s') | int %}
{% if ansiboard_group_charts | default([]) | length > 0 and groups['all'] | length > 0 %}
   <div style="display: flex; flex-wrap: wrap; gap: 32px; margin-bottom: 24px; justify-content: center;">
{% for chart in ansiboard_group_charts %}
{%   set ns = namespace(values=[]) %}
{%   for member in groups['all'] %}
{%     set facts = hostvars[member].ansible_facts | default({}) %}
{%     set ns.values = ns.values + [facts[chart.key] | default('Unknown') | string] %}
{%   endfor %}
{%   set unique = ns.values | unique | sort %}
{%   set total = ns.values | length %}
{%   set grad = namespace(offset=0, parts=[]) %}
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
{%     set pct = (uv_count / total * 100) | round(1) %}
{%     set color = colors[loop.index0 % (colors | length)] %}
{%     if loop.last %}
{%       set grad.parts = grad.parts + [color ~ ' ' ~ grad.offset ~ '% 100%'] %}
{%     else %}
{%       set grad.parts = grad.parts + [color ~ ' ' ~ grad.offset ~ '% ' ~ (grad.offset + pct) ~ '%'] %}
{%     endif %}
{%     set grad.offset = grad.offset + pct %}
{%   endfor %}
    <div class="chart-card">
     <div style="position: relative; width: 110px; height: 110px; flex-shrink: 0;">
      <div style="width: 110px; height: 110px; border-radius: 50%; background: conic-gradient({{ grad.parts | join(', ') }});"></div>
      <div class="donut-hole" style="position: absolute; top: 27px; left: 27px; width: 56px; height: 56px; border-radius: 50%;"></div>
     </div>
     <div>
      <div style="font-weight: 500; font-size: 14px; margin-bottom: 8px;">{{ chart.label }}</div>
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
{%     set pct = (uv_count / total * 100) | round(0) | int %}
      <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; line-height: 1.8;">
       <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: {{ colors[loop.index0 % (colors | length)] }}; flex-shrink: 0;"></span>
       {{ uv }} <span style="color: #999;">({{ uv_count }}, {{ pct }}%)</span>
      </div>
{%   endfor %}
     </div>
    </div>
{% endfor %}
   </div>
{% endif %}
   <table>
    <thead>
     <tr>
{% for col in ansiboard_group_columns %}
      <th>{{ col.label }}</th>
{% endfor %}
     </tr>
    </thead>
    <tbody>
{% for l_member in groups['all'] | sort %}
{%   set facts = hostvars[l_member].ansible_facts | default({}) %}
     <tr>
{% for col in ansiboard_group_columns %}
{%   set fmt = col.format | default('') %}
{%   if fmt == 'cores' %}
{%     set cores = facts.processor_cores | default('') %}
{%     set vcpus = facts.processor_vcpus | default('') %}
{%     if cores and vcpus and cores != vcpus %}
{%       set value = cores ~ '/' ~ vcpus %}
{%     elif vcpus %}
{%       set value = vcpus %}
{%     else %}
{%       set value = '' %}
{%     endif %}
{%   elif fmt == 'mem_gib' %}
{%     set mb = facts[col.key] | default(0) | int %}
{%     if mb > 0 %}
{%       set value = (mb / 1024) | round(0, 'ceil') | int %}
{%     else %}
{%       set value = '' %}
{%     endif %}
{%   elif fmt == 'ipv4' %}
{%     set value = facts[col.key].address | default('') %}
{%   elif fmt == 'uptime' %}
{%     set secs = facts[col.key] | default(0) | int %}
{%     if secs >= 86400 %}
{%       set value = (secs // 86400) ~ 'd' %}
{%     elif secs >= 3600 %}
{%       set value = (secs // 3600) ~ 'h' %}
{%     elif secs > 0 %}
{%       set value = (secs // 60) ~ 'm' %}
{%     else %}
{%       set value = '' %}
{%     endif %}
{%   elif fmt == 'facts_age' %}
{%     set epoch = facts.date_time.epoch | default(0) | int %}
{%     if epoch > 0 %}
{%       set age = now_epoch - epoch %}
{%       if age >= 86400 %}
{%         set value = (age // 86400) ~ 'd' %}
{%         set is_stale = age >= 172800 %}
{%       elif age >= 3600 %}
{%         set value = (age // 3600) ~ 'h' %}
{%         set is_stale = false %}
{%       elif age >= 0 %}
{%         set value = (age // 60) ~ 'm' %}
{%         set is_stale = false %}
{%       else %}
{%         set value = '' %}
{%         set is_stale = false %}
{%       endif %}
{%     else %}
{%       set value = '' %}
{%       set is_stale = false %}
{%     endif %}
{%   else %}
{%     set value = facts[col.key] | default('') %}
{%   endif %}
{%   if loop.first %}
      <td><a href="hosts/{{ l_member }}.html">{{ value if value else l_member }}</a></td>
{%   elif fmt == 'facts_age' and value and is_stale | default(false) %}
      <td class="stale">{{ value }}</td>
{%   elif value %}
      <td>{{ value }}</td>
{%   else %}
      <td class="na">n/a</td>
{%   endif %}
{% endfor %}
     </tr>
{% endfor %}
    </tbody>
   </table>
  </div>
  <script>
  document.querySelectorAll('th').forEach(function(th, i) {
    th.addEventListener('click', function() {
      var table = th.closest('table');
      var tbody = table.querySelector('tbody');
      var rows = Array.from(tbody.querySelectorAll('tr'));
      var dir = th.dataset.sort === 'asc' ? 'desc' : 'asc';
      th.closest('thead').querySelectorAll('th').forEach(function(h) { h.dataset.sort = ''; });
      th.dataset.sort = dir;
      rows.sort(function(a, b) {
        var av = a.cells[i].textContent.trim();
        var bv = b.cells[i].textContent.trim();
        var an = parseFloat(av), bn = parseFloat(bv);
        if (!isNaN(an) && !isNaN(bn)) return dir === 'asc' ? an - bn : bn - an;
        return dir === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
      });
      rows.forEach(function(r) { tbody.appendChild(r); });
    });
  });
  </script>
 </body>
</html>
