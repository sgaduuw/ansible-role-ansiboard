<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AnsiBoard</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    .container { max-width: 900px; margin: 0 auto; }
    .stats { color: #666; font-size: 14px; margin-bottom: 20px; }
    .stats a { color: #0066cc; text-decoration: none; font-weight: 500; }
    .stats a:hover { text-decoration: underline; }
    .card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 8px; }
    .card a { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; text-decoration: none; color: #333; }
    .card a:hover { background: #f9f9f9; }
    .card .name { font-weight: 500; }
    .card .count { color: #666; font-size: 14px; }
    .chart-card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; display: flex; align-items: center; gap: 16px; }
    .donut-hole { background: #fff; }
    .timestamp { color: #999; font-size: 13px; margin-top: 20px; }
    h2 { font-size: 16px; font-weight: 500; margin: 24px 0 12px; color: #666; }
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a1a; color: #e0e0e0; }
      .card, .chart-card { background: #2a2a2a; border-color: #404040; }
      .card a { color: #e0e0e0; }
      .card a:hover { background: #333; }
      .card .count { color: #999; }
      .stats { color: #999; }
      .stats a { color: #6cb6ff; }
      .timestamp { color: #666; }
      h2 { color: #999; }
      .donut-hole { background: #2a2a2a; }
    }
  </style>
 </head>
 <body>
  <div class="container">
   <h1>AnsiBoard</h1>
   <p class="stats"><a href="groups/all.html">{{ groups['all'] | length }} hosts</a> across {{ groups | length }} groups</p>
{% set colors = ['#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f', '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ac'] %}
{% if ansiboard_group_charts | default([]) | length > 0 and groups['all'] | length > 0 %}
   <div style="display: flex; flex-wrap: wrap; gap: 24px; margin-bottom: 24px; justify-content: center;">
{% for chart in ansiboard_group_charts %}
{%   set ns = namespace(values=[]) %}
{%   for member in groups['all'] %}
{%     set facts = hostvars[member].ansible_facts | default({}) %}
{%     set ns.values = ns.values + [facts[chart.key] | default('Unknown') | string] %}
{%   endfor %}
{%   set unique = ns.values | unique | sort %}
{%   set total = ns.values | length %}
{%   set grad = namespace(cum_count=0, prev_stop=0, parts=[], pcts=[]) %}
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
{%     set grad.cum_count = grad.cum_count + uv_count %}
{%     set stop = (grad.cum_count / total * 100) | round(0) | int %}
{%     set color = colors[loop.index0 % (colors | length)] %}
{%     set grad.parts = grad.parts + [color ~ ' ' ~ grad.prev_stop ~ '% ' ~ stop ~ '%'] %}
{%     set grad.pcts = grad.pcts + [stop - grad.prev_stop] %}
{%     set grad.prev_stop = stop %}
{%   endfor %}
    <div class="chart-card">
     <div style="position: relative; width: 80px; height: 80px; flex-shrink: 0;">
      <div style="width: 80px; height: 80px; border-radius: 50%; background: conic-gradient({{ grad.parts | join(', ') }});"></div>
      <div class="donut-hole" style="position: absolute; top: 20px; left: 20px; width: 40px; height: 40px; border-radius: 50%;"></div>
     </div>
     <div>
      <div style="font-weight: 500; font-size: 13px; margin-bottom: 6px;">{{ chart.label | e }}</div>
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
      <div style="display: flex; align-items: center; gap: 6px; font-size: 12px; line-height: 1.7;">
       <span style="display: inline-block; width: 8px; height: 8px; border-radius: 2px; background: {{ colors[loop.index0 % (colors | length)] }}; flex-shrink: 0;"></span>
       {{ uv | e }} <span style="color: #999;">({{ uv_count }})</span>
      </div>
{%   endfor %}
     </div>
    </div>
{% endfor %}
   </div>
{% endif %}
   <h2>Groups</h2>
{% for l_group in groups | sort %}
   <div class="card">
    <a href="groups/{{ l_group }}.html">
     <span class="name">{{ l_group }}</span>
     <span class="count">{{ groups[l_group] | length }} host{{ 's' if groups[l_group] | length != 1 }}</span>
    </a>
   </div>
{% endfor %}
{% set l_ns = namespace(max_epoch=0) %}
{% for l_host in groups['all'] %}
{%   set l_epoch = hostvars[l_host].ansible_facts.date_time.epoch | default(0) | int %}
{%   if l_epoch > l_ns.max_epoch %}{% set l_ns.max_epoch = l_epoch %}{% endif %}
{% endfor %}
   <p class="timestamp">Data as of <span id="data-as-of" data-epoch="{{ l_ns.max_epoch }}">—</span></p>
   <script>
    (function() {
      var el = document.getElementById('data-as-of');
      var ep = parseInt(el.getAttribute('data-epoch'), 10);
      el.textContent = ep > 0 ? new Date(ep * 1000).toLocaleString() : 'unknown';
    })();
   </script>
  </div>
 </body>
</html>
