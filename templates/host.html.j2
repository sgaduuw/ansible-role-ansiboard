<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AnsiBoard - {{ item.value.ansible_facts.hostname | default(item.key) }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    .breadcrumb { margin-bottom: 20px; font-size: 14px; }
    .breadcrumb a { color: #0066cc; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .container { max-width: 900px; margin: 0 auto; }
    .subtitle { color: #666; font-size: 14px; margin-bottom: 20px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 20px; }
    th { text-align: left; padding: 10px 16px; background: #f9f9f9; border-bottom: 1px solid #e0e0e0; font-weight: 500; font-size: 14px; color: #666; width: 220px; }
    td { padding: 10px 16px; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
    tr:last-child td, tr:last-child th { border-bottom: none; }
    details { margin-top: 16px; }
    summary { cursor: pointer; font-size: 14px; color: #666; padding: 8px 0; }
    pre { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; overflow-x: auto; font-size: 13px; line-height: 1.5; }
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a1a; color: #e0e0e0; }
      table { background: #2a2a2a; border-color: #404040; }
      th { background: #333; border-color: #404040; color: #999; }
      td { border-color: #333; }
      .breadcrumb a { color: #6cb6ff; }
      .subtitle { color: #999; }
      summary { color: #999; }
      pre { background: #2a2a2a; border-color: #404040; color: #ccc; }
    }
  </style>
 </head>
 <body>
  <div class="container">
   <div class="breadcrumb"><a href="../index.html">AnsiBoard</a> / {{ item.value.ansible_facts.hostname | default(item.key) }}</div>
   <h1>{{ item.value.ansible_facts.hostname | default(item.key) }}</h1>
   <p class="subtitle">{{ item.value.ansible_facts.fqdn | default('') }}</p>
   <table>
{% for fact in ansiboard_host_facts %}
{%   set value = item.value.ansible_facts[fact.key] | default('n/a') %}
    <tr><th>{{ fact.label }}</th><td>{{ value }}</td></tr>
{% endfor %}
   </table>
   <details>
    <summary>Show all gathered facts</summary>
    <pre>{{ item.value.ansible_facts | to_nice_json }}</pre>
   </details>
  </div>
 </body>
</html>
