<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AnsiBoard - {{ item.key | e }}</title>
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/gridjs@6.2.0/dist/theme/mermaid.min.css"
        integrity="sha384-i8iPOOXHyYKlqvjJjbORq7m/VrfUhgupTg3IZvtXz8M7c0CiTPUUhM5gdjiQiGbv"
        crossorigin="anonymous"
        referrerpolicy="no-referrer">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    .breadcrumb { margin-bottom: 20px; font-size: 14px; }
    .breadcrumb a { color: #0066cc; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .container { max-width: 1400px; margin: 0 auto; }
    .count { color: #666; font-size: 14px; margin-bottom: 16px; }
    .chart-card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; display: flex; align-items: center; gap: 20px; }
    .donut-hole { background: #fff; }
    .export-btn { display: inline-block; margin-bottom: 12px; padding: 6px 14px; font-size: 13px; border: 1px solid #e0e0e0; border-radius: 4px; background: #fff; color: #333; cursor: pointer; text-decoration: none; }
    .export-btn:hover { background: #f0f0f0; }
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a1a; color: #e0e0e0; }
      .chart-card { background: #2a2a2a; border-color: #404040; }
      .donut-hole { background: #2a2a2a; }
      .breadcrumb a { color: #6cb6ff; }
      .count { color: #999; }
      .export-btn { background: #2a2a2a; border-color: #404040; color: #e0e0e0; }
      .export-btn:hover { background: #333; }
      .gridjs-container { --gridjs-border-color: #404040; }
      .gridjs-wrapper { border-color: #404040; }
      .gridjs-table { background: #2a2a2a; }
      .gridjs-thead th { background: #333 !important; color: #999; border-color: #404040; }
      .gridjs-thead th:hover { color: #e0e0e0; }
      .gridjs-thead .gridjs-th-sort:hover, .gridjs-thead .gridjs-th-sort:focus { background: #404040 !important; }
      .gridjs-tbody td { background: #2a2a2a; color: #e0e0e0; border-color: #333; }
      .gridjs-tbody tr:hover td { background: #333; }
      .gridjs-search-input { background: #2a2a2a !important; color: #e0e0e0 !important; border-color: #404040 !important; }
      .gridjs-footer { background: #2a2a2a; border-color: #404040; }
      .gridjs-pagination .gridjs-pages button { background: #2a2a2a; color: #e0e0e0; border-color: #404040; }
      .gridjs-pagination .gridjs-pages button:hover { background: #333 !important; color: #e0e0e0 !important; }
      .gridjs-pagination .gridjs-pages { background: transparent; }
      .gridjs-pagination .gridjs-pages button.gridjs-currentPage { background: #404040; }
      .gridjs-pagination .gridjs-summary { color: #999; }
      td a { color: #e0e0e0; }
      td a:hover { color: #6cb6ff; }
    }
  </style>
 </head>
 <body>
  <div class="container">
   <div class="breadcrumb"><a href="../index.html">AnsiBoard</a> / {{ item.key | e }}</div>
   <h1>{{ item.key | e }}</h1>
   <p class="count">{{ groups[item.key] | length }} host{{ 's' if groups[item.key] | length != 1 }}</p>
{% set colors = ['#4e79a7', '#f28e2b', '#e15759', '#76b7b2', '#59a14f', '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ac'] %}
{% if ansiboard_group_charts | default([]) | length > 0 and groups[item.key] | length > 0 %}
   <div style="display: flex; flex-wrap: wrap; gap: 32px; margin-bottom: 24px; justify-content: center;">
{% for chart in ansiboard_group_charts %}
{%   set ns = namespace(values=[]) %}
{%   for member in groups[item.key] %}
{%     set facts = hostvars[member].ansible_facts | default({}) %}
{%     set ns.values = ns.values + [facts[chart.key] | default('Unknown') | string] %}
{%   endfor %}
{%   set unique = ns.values | unique | sort %}
{%   set total = ns.values | length %}
{%   set grad = namespace(cum_count=0, prev_stop=0, parts=[], pcts=[]) %}
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
{%     set grad.cum_count = grad.cum_count + uv_count %}
{%     set stop = (grad.cum_count / total * 100) | round(0) | int %}
{%     set color = colors[loop.index0 % (colors | length)] %}
{%     set grad.parts = grad.parts + [color ~ ' ' ~ grad.prev_stop ~ '% ' ~ stop ~ '%'] %}
{%     set grad.pcts = grad.pcts + [stop - grad.prev_stop] %}
{%     set grad.prev_stop = stop %}
{%   endfor %}
    <div class="chart-card">
     <div style="position: relative; width: 110px; height: 110px; flex-shrink: 0;">
      <div style="width: 110px; height: 110px; border-radius: 50%; background: conic-gradient({{ grad.parts | join(', ') }});"></div>
      <div class="donut-hole" style="position: absolute; top: 27px; left: 27px; width: 56px; height: 56px; border-radius: 50%;"></div>
     </div>
     <div>
      <div style="font-weight: 500; font-size: 14px; margin-bottom: 8px;">{{ chart.label | e }}</div>
{%   for uv in unique %}
{%     set uv_count = ns.values | select('equalto', uv) | list | length %}
      <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; line-height: 1.8;">
       <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: {{ colors[loop.index0 % (colors | length)] }}; flex-shrink: 0;"></span>
       {{ uv | e }} <span style="color: #999;">({{ uv_count }}, {{ grad.pcts[loop.index0] }}%)</span>
      </div>
{%   endfor %}
     </div>
    </div>
{% endfor %}
   </div>
{% endif %}
   <a href="#" class="export-btn" id="export-csv">Export CSV</a>
   <div id="grid"></div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/gridjs@6.2.0/dist/gridjs.umd.js"
          integrity="sha384-y62I+ZvjNRolkugL/AMpUZykqrL6oqYxBruObmlDAhDpmapM0s+xgvVK+wGVpza0"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"></script>
  <script>
  function escapeHtml(s) {
    var d = document.createElement('div');
    d.appendChild(document.createTextNode(s));
    return d.innerHTML;
  }
  function formatAge(cell) {
    var epoch = parseInt(cell, 10);
    if (!epoch) return '';
    var age = Math.max(0, Math.floor(Date.now() / 1000) - epoch);
    if (age >= 86400) return Math.floor(age / 86400) + 'd';
    if (age >= 3600)  return Math.floor(age / 3600)  + 'h';
    return Math.floor(age / 60) + 'm';
  }
  var tableData = [
{% for l_member in groups[item.key] | sort %}
{%   set facts = hostvars[l_member].ansible_facts | default({}) %}
    [
{% for col in ansiboard_group_columns %}
{%   set fmt = col.format | default('') %}
{%   if fmt == 'cores' %}
{%     set cores = facts.processor_cores | default('') %}
{%     set vcpus = facts.processor_vcpus | default('') %}
{%     if cores and vcpus and cores != vcpus %}
{%       set value = cores ~ '/' ~ vcpus %}
{%     elif vcpus %}
{%       set value = vcpus %}
{%     else %}
{%       set value = '' %}
{%     endif %}
{%   elif fmt == 'mem_gib' %}
{%     set mb = facts[col.key] | default(0) | int %}
{%     set value = ((mb / 1024) | round(0, 'ceil') | int) if mb > 0 else 0 %}
{%   elif fmt == 'ipv4' %}
{%     set value = facts[col.key].address | default('') %}
{%   elif fmt == 'uptime' %}
{%     set value = facts[col.key] | default(0) | int %}
{%   elif fmt == 'facts_age' %}
{%     set value = facts.date_time.epoch | default(0) | int %}
{%   else %}
{%     set value = facts[col.key] | default('') %}
{%   endif %}
{%   if loop.first %}
      {{ l_member | tojson }},
{%   elif fmt in ['mem_gib', 'uptime', 'facts_age'] %}
      {{ value | tojson }},
{%   else %}
      {{ value | string | tojson }},
{%   endif %}
{% endfor %}
    ],
{% endfor %}
  ];
  var columns = [
{% for col in ansiboard_group_columns %}
{%   if loop.first %}
    {
      name: {{ col.label | tojson }},
      formatter: function(cell) {
        return gridjs.html('<a href="../hosts/' + encodeURIComponent(cell) + '.html">' + escapeHtml(cell) + '</a>');
      }
    },
{%   elif col.format | default('') == 'facts_age' %}
    {
      name: {{ col.label | tojson }},
      sort: { compare: function(a, b) { return parseInt(b, 10) - parseInt(a, 10); } },
      formatter: function(cell) {
        var epoch = parseInt(cell, 10);
        var label = formatAge(cell);
        if (epoch && (Math.floor(Date.now() / 1000) - epoch) >= 172800) {
          return gridjs.html('<span style="color: #e15759;">' + escapeHtml(label) + '</span>');
        }
        return label;
      }
    },
{%   elif col.format | default('') == 'uptime' %}
    {
      name: {{ col.label | tojson }},
      formatter: function(cell) {
        var n = parseInt(cell, 10);
        if (isNaN(n) || n < 0) return '';
        return Math.floor(n / 86400) + 'd';
      }
    },
{%   elif col.format | default('') == 'mem_gib' %}
    {
      name: {{ col.label | tojson }},
      formatter: function(cell) {
        var n = parseInt(cell, 10);
        return (isNaN(n) || n <= 0) ? '' : String(n);
      }
    },
{%   elif col.format | default('') == 'cores' %}
    {
      name: {{ col.label | tojson }},
      sort: { compare: function(a, b) {
        var na = parseInt(a, 10);
        var nb = parseInt(b, 10);
        if (isNaN(na)) na = -1;
        if (isNaN(nb)) nb = -1;
        return na - nb;
      } }
    },
{%   else %}
    {{ col.label | tojson }},
{%   endif %}
{% endfor %}
  ];
  new gridjs.Grid({
    columns: columns,
    data: tableData,
    search: true,
    sort: true,
    pagination: { limit: 50 },
    autoWidth: true,
    style: { table: { 'white-space': 'nowrap' } }
  }).render(document.getElementById('grid'));

  document.getElementById('export-csv').addEventListener('click', function(e) {
    e.preventDefault();
    var headers = [
{% for col in ansiboard_group_columns %}
      {{ col.label | tojson }},
{% endfor %}
    ];
    var columnFormats = [{% for col in ansiboard_group_columns %}{{ col.format | default('') | tojson }},{% endfor %}];
    function csvValue(cell, fmt) {
      if (fmt === 'facts_age') return formatAge(cell);
      if (fmt === 'uptime') {
        var n = parseInt(cell, 10);
        return (isNaN(n) || n < 0) ? '' : String(Math.floor(n / 86400));
      }
      return String(cell);
    }
    var csv = headers.join(',') + '\n';
    tableData.forEach(function(row) {
      csv += row.map(function(cell, i) {
        var val = csvValue(cell, columnFormats[i]);
        if (val.indexOf(',') > -1 || val.indexOf('"') > -1) {
          return '"' + val.replace(/"/g, '""') + '"';
        }
        return val;
      }).join(',') + '\n';
    });
    var blob = new Blob([csv], { type: 'text/csv' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = {{ (item.key ~ '.csv') | tojson }};
    a.click();
  });
  </script>
 </body>
</html>
