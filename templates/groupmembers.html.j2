<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AnsiBoard - {{ item.key }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    .breadcrumb { margin-bottom: 20px; font-size: 14px; }
    .breadcrumb a { color: #0066cc; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .container { max-width: 900px; margin: 0 auto; }
    .card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 8px; }
    .card a { display: block; padding: 12px 16px; text-decoration: none; color: #333; font-weight: 500; }
    .card a:hover { background: #f9f9f9; }
    .count { color: #666; font-size: 14px; margin-bottom: 16px; }
  </style>
 </head>
 <body>
  <div class="container">
   <div class="breadcrumb"><a href="../index.html">AnsiBoard</a> / {{ item.key }}</div>
   <h1>{{ item.key }}</h1>
   <p class="count">{{ groups[item.key] | length }} host{{ 's' if groups[item.key] | length != 1 }}</p>
{% for l_member in groups[item.key] | sort %}
   <div class="card">
    <a href="../hosts/{{ l_member }}.html">{{ l_member }}</a>
   </div>
{% endfor %}
  </div>
 </body>
</html>
